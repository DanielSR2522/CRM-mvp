# SmarTrack CRM — environment variables
#
# Copy to .env.local and fill in. Never commit .env.local.
# Values below are NAMES ONLY — no real secret belongs in this file.

# ---------------------------------------------------------------------------
# Supabase — public
# ---------------------------------------------------------------------------
# Safe to expose: the anon key is designed to be public and is useless without a
# session, because every table is protected by row level security.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Supabase — server only
# ---------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY bypasses EVERY row level security policy. It is the
# most dangerous value in this project.
#
#   - it MUST NOT be prefixed with NEXT_PUBLIC_ (that would bundle it into the
#     browser and publish it to the internet);
#   - it MUST NOT be imported outside src/lib/supabaseAdmin.ts;
#   - it MUST NOT be logged, echoed in an error, or committed.
#
# It exists for one reason: the public signing page at /sign/[token] has no
# session, so RLS cannot authorise it. The server validates the token, its
# expiry, its revocation and the request's status itself — bypassing RLS does not
# remove that obligation, it creates it.
#
# Find it in: Supabase Dashboard -> Project Settings -> API -> service_role.
#
# The app builds and runs without this. The public signing routes will return a
# generic 503 until it is set.

SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Application URL — optional
# ---------------------------------------------------------------------------
# The origin used to build signing links (https://your-app.com/sign/<token>).
#
# Leave empty in most cases: links are built from the browser's own origin, which
# is correct by definition. Set it only when the CRM is reached through a
# hostname clients cannot resolve — an internal proxy, say — since a wrong value
# here hands clients links that silently 404.
#
# No trailing slash.

NEXT_PUBLIC_APP_URL=

# ---------------------------------------------------------------------------
# Health Policies Encryption
# ---------------------------------------------------------------------------
# Secure 32-byte key encoded in Base64 (validated as exactly 32 bytes when decoded).
# Do not prefix with NEXT_PUBLIC_.
# Do not commit real keys.
HEALTH_DATA_ENCRYPTION_KEY=
